postgres_admin_password = "replace-with-a-strong-password"

# Add your public IPv4 address to allow local app connections.
# Example:
# allowed_ip_addresses = ["203.0.113.10"]
allowed_ip_addresses = []

# Optional named IPv4 ranges. Country-wide allowlists are usually too large for
# database firewall rules; prefer specific office/VPN/static ISP ranges.
# Example:
# allowed_ip_ranges = {
#   office = {
#     start_ip_address = "203.0.113.10"
#     end_ip_address   = "203.0.113.20"
#   }
# }
allowed_ip_ranges = {}
